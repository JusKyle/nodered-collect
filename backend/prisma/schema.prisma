generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Gateway {
  id            String         @id @default(cuid())
  name          String
  address       String
  port          Int            @default(1880)
  adminToken    String
  status        GatewayStatus  @default(OFFLINE)
  lastHeartbeat DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  deviceInstances DeviceInstance[]
  syncRecords     SyncRecord[]

  @@unique([address, port])
}

enum GatewayStatus {
  ONLINE
  OFFLINE
  ERROR
  TOKEN_EXPIRED
}

enum ModelStatus {
  ENABLED
  DISABLED
}

model DeviceModel {
  id          String          @id @default(cuid())
  name        String
  vendor      String
  model       String
  protocol    String
  description String?
  points      Json            @default("[]")
  status      ModelStatus     @default(ENABLED)
  version     String          @default("v1.0")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  deviceInstances DeviceInstance[]
  versions        ModelVersion[]

  @@unique([name, vendor, model])
}

model ModelVersion {
  id          String      @id @default(cuid())
  modelId     String
  version     String
  points      Json        @default("[]")
  createdAt   DateTime    @default(now())

  model       DeviceModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
}

model DeviceInstance {
  id              String         @id @default(cuid())
  name            String
  modelId         String
  gatewayId       String
  nodeId          String
  config          Json?
  status          DeviceStatus  @default(OFFLINE)
  lastSyncTime    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  model           DeviceModel   @relation(fields: [modelId], references: [id])
  gateway         Gateway       @relation(fields: [gatewayId], references: [id])
  syncRecords     SyncRecord[]

  @@unique([gatewayId, nodeId])
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  SYNCING
  ERROR
  PENDING
  UNBOUND
  PENDING_SYNC
  RUNNING
}

model SyncRecord {
  id              String          @id @default(cuid())
  type            SyncType
  gatewayId       String
  deviceInstanceId String?
  status          SyncStatus
  message         String?
  payload         Json?
  createdAt       DateTime       @default(now())

  gateway         Gateway        @relation(fields: [gatewayId], references: [id])
  deviceInstance  DeviceInstance? @relation(fields: [deviceInstanceId], references: [id])
}

enum SyncType {
  DEPLOY
  UNDEPLOY
  HEARTBEAT
  CONFIG_SYNC
  DATA_UPLOAD
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

model RegistrationCode {
  id          String    @id @default(cuid())
  code        String    @unique
  gatewayName String
  expiresAt   DateTime
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now())
}