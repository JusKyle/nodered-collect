generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Gateway {
  id                String         @id @default(cuid())
  name              String
  address           String
  port              Int            @default(1880)
  adminToken        String
  status            GatewayStatus  @default(OFFLINE)
  lastHeartbeat     DateTime?
  heartbeatInterval Int            @default(30)
  heartbeatTimeout  Int            @default(90)
  nodeRedVersion    String?
  ip                String?
  flowCount         Int?
  cacheEnabled      Boolean?       // 网关级缓存开关（null=使用平台默认）
  cacheRetentionDays Int?          // 缓存保存期限（天）
  cacheReplayRate   Int?           // 缓存补发速率（条/秒）
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  deviceInstances DeviceInstance[]
  syncRecords     SyncRecord[]
  dataPoints      DeviceDataPoint[]
  registrationCodes RegistrationCode[]
  performances    GatewayPerformance[]
  cacheStatus     GatewayCacheStatus?

  @@unique([address, port])
}

enum GatewayStatus {
  ONLINE
  OFFLINE
  ERROR
  TOKEN_EXPIRED
}

enum ModelStatus {
  ENABLED
  DISABLED
}

enum DataType {
  INT16
  UINT16
  INT32
  UINT32
  FLOAT32
  FLOAT64
  BOOL
  STRING
}

model DeviceModel {
  id          String          @id @default(cuid())
  name        String
  vendor      String
  model       String
  protocol    String
  description String?
  points      Json            @default("[]")
  status      ModelStatus     @default(ENABLED)
  version     Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  deviceInstances DeviceInstance[]
  versions        ModelVersion[]
  pointModels     PointModel[]

  @@unique([name, vendor, model])
}

model PointModel {
  id          String     @id @default(cuid())
  modelId     String
  name        String
  tag         String
  dataType    DataType
  address     String
  unit        String?
  description String?
  config      Json       @default("{}")
  sort        Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  model       DeviceModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, tag])
  @@index([modelId, sort])
}

model ModelVersion {
  id          String      @id @default(cuid())
  modelId     String
  version     Int
  points      Json        @default("[]")
  createdAt   DateTime    @default(now())

  model       DeviceModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
}

model DeviceInstance {
  id              String         @id @default(cuid())
  name            String
  description     String?
  modelId         String
  gatewayId       String?
  nodeId          String         @default("")
  deviceId        String?        // 业务唯一ID
  group           String?        // 分组
  config          Json?
  commConfig      Json?          // 通信参数（IP、端口、从站地址等）
  status          DeviceStatus  @default(OFFLINE)
  templateVersion Int            @default(1)   // 当前同步的模板版本号
  deployedVersion Int?           // 最后下发的版本号
  collectStatus   String         @default("STOPPED")  // 采集状态: RUNNING/STOPPED
  enabled         Boolean        @default(true)
  lastSyncTime    DateTime?
  lastDataTime    DateTime?
  cacheEnabled    Boolean?       // 设备级缓存开关（可选，覆盖网关设置）
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  model           DeviceModel   @relation(fields: [modelId], references: [id])
  gateway         Gateway?      @relation(fields: [gatewayId], references: [id])
  syncRecords     SyncRecord[]
  dataPoints      DeviceDataPoint[]
  points          DevicePoint[]

  @@unique([gatewayId, nodeId])
  @@index([gatewayId])
  @@index([modelId])
  @@index([status])
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  DISABLED
  COLLECTING
  ERROR
}

model SyncRecord {
  id              String          @id @default(cuid())
  type            SyncType
  gatewayId       String
  deviceInstanceId String?
  status          SyncStatus
  message         String?
  payload         Json?
  createdAt       DateTime       @default(now())

  gateway         Gateway        @relation(fields: [gatewayId], references: [id])
  deviceInstance  DeviceInstance? @relation(fields: [deviceInstanceId], references: [id])
}

enum SyncType {
  DEPLOY
  UNDEPLOY
  HEARTBEAT
  CONFIG_SYNC
  DATA_UPLOAD
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

model DeviceDataPoint {
  id               String    @id @default(cuid())
  deviceInstanceId String
  gatewayId        String
  pointCode       String
  pointName       String
  value           String
  dataType        String
  timestamp       DateTime
  receivedAt      DateTime  @default(now())
  quality         Int       @default(0)

  instance DeviceInstance @relation(fields: [deviceInstanceId], references: [id])
  gateway  Gateway        @relation(fields: [gatewayId], references: [id])

  @@index([deviceInstanceId, pointCode, timestamp(sort: Desc)])
  @@index([gatewayId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
}

enum CodeStatus {
  UNUSED
  USED
  EXPIRED
  REVOKED
}

model RegistrationCode {
  id          String     @id @default(cuid())
  code        String     @unique
  batchId     String?
  status      CodeStatus @default(UNUSED)
  expiresAt   DateTime
  gatewayId   String?
  usedAt      DateTime?
  revokedAt   DateTime?
  createdAt   DateTime   @default(now())

  gateway Gateway? @relation(fields: [gatewayId], references: [id])
}

model PlatformConfig {
  id                String   @id @default("singleton")
  cacheEnabled      Boolean  @default(false)
  cacheRetentionDays Int     @default(15)
  cacheReplayRate   Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GatewayPerformance {
  id           String   @id @default(cuid())
  gatewayId    String
  cpuUsage     Float?
  memoryUsage  Float?
  diskUsage    Float?
  diskFreeBytes BigInt?
  timestamp    DateTime @default(now())
  createdAt    DateTime @default(now())

  gateway Gateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@index([gatewayId, timestamp(sort: Desc)])
}

model GatewayCacheStatus {
  id               String        @id @default(cuid())
  gatewayId        String        @unique
  cachingEnabled   Boolean       @default(false)
  isCaching        Boolean       @default(false)
  cacheCount       Int           @default(0)
  cacheSizeBytes   BigInt        @default(0)
  replayCount      Int           @default(0)
  replayRate       Int           @default(100)
  replayStatus     ReplayStatus  @default(IDLE)
  firstCachedAt    DateTime?
  latestCachedAt   DateTime?
  replayStartedAt  DateTime?
  replayFinishedAt DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  gateway Gateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
}

enum ReplayStatus {
  IDLE
  REPLAYING
  PAUSED
  COMPLETED
}

enum PointSource {
  TEMPLATE
  DEVICE
}

model DevicePoint {
  id          String      @id @default(cuid())
  instanceId  String
  name        String
  tag         String
  dataType    DataType
  address     String
  unit        String?
  description String?
  config      Json        @default("{}")
  enabled     Boolean     @default(true)
  source      PointSource @default(DEVICE)
  sort        Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  instance    DeviceInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, tag])
  @@index([instanceId])
  @@index([instanceId, source])
}