generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Gateway {
  id                String         @id @default(cuid())
  name              String
  address           String
  port              Int            @default(1880)
  adminToken        String
  status            GatewayStatus  @default(OFFLINE)
  lastHeartbeat     DateTime?
  heartbeatInterval Int            @default(30)
  heartbeatTimeout  Int            @default(90)
  nodeRedVersion    String?
  ip                String?
  flowCount         Int?
  cacheEnabled      Boolean?       // 网关级缓存开关（null=使用平台默认）
  cacheRetentionDays Int?          // 缓存保存期限（天）
  cacheReplayRate   Int?           // 缓存补发速率（条/秒）
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  deviceInstances DeviceInstance[]
  syncRecords     SyncRecord[]
  dataPoints      DeviceDataPoint[]
  registrationCodes RegistrationCode[]
  performances    GatewayPerformance[]
  cacheStatus     GatewayCacheStatus?

  @@unique([address, port])
}

enum GatewayStatus {
  ONLINE
  OFFLINE
  ERROR
  TOKEN_EXPIRED
}

enum ModelStatus {
  ENABLED
  DISABLED
}

model DeviceModel {
  id          String          @id @default(cuid())
  name        String
  vendor      String
  model       String
  protocol    String
  description String?
  points      Json            @default("[]")
  status      ModelStatus     @default(ENABLED)
  version     String          @default("v1.0")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  deviceInstances DeviceInstance[]
  versions        ModelVersion[]

  @@unique([name, vendor, model])
}

model ModelVersion {
  id          String      @id @default(cuid())
  modelId     String
  version     String
  points      Json        @default("[]")
  createdAt   DateTime    @default(now())

  model       DeviceModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
}

model DeviceInstance {
  id              String         @id @default(cuid())
  name            String
  modelId         String
  gatewayId       String
  nodeId          String
  config          Json?
  status          DeviceStatus  @default(OFFLINE)
  lastSyncTime    DateTime?
  lastDataTime    DateTime?
  cacheEnabled    Boolean?       // 设备级缓存开关（可选，覆盖网关设置）
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  model           DeviceModel   @relation(fields: [modelId], references: [id])
  gateway         Gateway       @relation(fields: [gatewayId], references: [id])
  syncRecords     SyncRecord[]
  dataPoints      DeviceDataPoint[]

  @@unique([gatewayId, nodeId])
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  SYNCING
  ERROR
  PENDING
  UNBOUND
  PENDING_SYNC
  RUNNING
}

model SyncRecord {
  id              String          @id @default(cuid())
  type            SyncType
  gatewayId       String
  deviceInstanceId String?
  status          SyncStatus
  message         String?
  payload         Json?
  createdAt       DateTime       @default(now())

  gateway         Gateway        @relation(fields: [gatewayId], references: [id])
  deviceInstance  DeviceInstance? @relation(fields: [deviceInstanceId], references: [id])
}

enum SyncType {
  DEPLOY
  UNDEPLOY
  HEARTBEAT
  CONFIG_SYNC
  DATA_UPLOAD
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

model DeviceDataPoint {
  id               String    @id @default(cuid())
  deviceInstanceId String
  gatewayId        String
  pointCode       String
  pointName       String
  value           String
  dataType        String
  timestamp       DateTime
  receivedAt      DateTime  @default(now())
  quality         Int       @default(0)

  instance DeviceInstance @relation(fields: [deviceInstanceId], references: [id])
  gateway  Gateway        @relation(fields: [gatewayId], references: [id])

  @@index([deviceInstanceId, pointCode, timestamp(sort: Desc)])
  @@index([gatewayId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
}

enum CodeStatus {
  UNUSED
  USED
  EXPIRED
  REVOKED
}

model RegistrationCode {
  id          String     @id @default(cuid())
  code        String     @unique
  batchId     String?
  status      CodeStatus @default(UNUSED)
  expiresAt   DateTime
  gatewayId   String?
  usedAt      DateTime?
  revokedAt   DateTime?
  createdAt   DateTime   @default(now())

  gateway Gateway? @relation(fields: [gatewayId], references: [id])
}

model PlatformConfig {
  id                String   @id @default("singleton")
  cacheEnabled      Boolean  @default(false)
  cacheRetentionDays Int     @default(15)
  cacheReplayRate   Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GatewayPerformance {
  id           String   @id @default(cuid())
  gatewayId    String
  cpuUsage     Float?
  memoryUsage  Float?
  diskUsage    Float?
  diskFreeBytes BigInt?
  timestamp    DateTime @default(now())
  createdAt    DateTime @default(now())

  gateway Gateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@index([gatewayId, timestamp(sort: Desc)])
}

model GatewayCacheStatus {
  id               String        @id @default(cuid())
  gatewayId        String        @unique
  cachingEnabled   Boolean       @default(false)
  isCaching        Boolean       @default(false)
  cacheCount       Int           @default(0)
  cacheSizeBytes   BigInt        @default(0)
  replayCount      Int           @default(0)
  replayRate       Int           @default(100)
  replayStatus     ReplayStatus  @default(IDLE)
  firstCachedAt    DateTime?
  latestCachedAt   DateTime?
  replayStartedAt  DateTime?
  replayFinishedAt DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  gateway Gateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
}

enum ReplayStatus {
  IDLE
  REPLAYING
  PAUSED
  COMPLETED
}